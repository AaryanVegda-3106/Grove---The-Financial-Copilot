# ══════════════════════════════════════════════════════════════
# Grove Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
APP_NAME=Grove API
APP_VERSION=0.1.0
DEBUG=True

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Clerk Auth ───────────────────────────────────────────────
# Get the JWKS URL from: https://dashboard.clerk.com → API Keys
# Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_AUDIENCE=

# ── NVIDIA NIM / LiteLLM (Dual-Model Routing) ───────────────
# Get your API key from: https://build.nvidia.com
# FAST  = lightweight model for greetings, definitions, simple Q&A
# STRONG = powerful model for analysis, planning, multi-step reasoning
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
LITELLM_MODEL_FAST=nvidia_nim/nvidia/llama-3.1-nemotron-nano-8b-v1
LITELLM_MODEL_STRONG=nvidia_nim/nvidia/llama-3.1-nemotron-70b-instruct

# ── Upstash Redis ────────────────────────────────────────────
# Get these from: https://console.upstash.com → Redis Database
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here
REDIS_TTL_SECONDS=3600

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
