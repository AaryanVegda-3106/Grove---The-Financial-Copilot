# ══════════════════════════════════════════════════════════
# Grove - Root .gitignore
# ══════════════════════════════════════════════════════════

# ── Environment / Secrets ─────────────────────────────────
.env
.env.*
!.env.example

# ── Frontend (Next.js) ────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
frontend/.vercel
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/coverage/

# ── Backend (Python / FastAPI) ────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Debug logs ────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pem

# ── Gemini / Agent ────────────────────────────────────────
.gemini/
